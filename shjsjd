<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <title>Карточка товара с переворотом</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f3f3f3;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
    }

    .product-card {
      width: 300px;
      height: 400px;
      perspective: 1000px; /* 3D эффект */
    }

    .product-card-inner {
      position: relative;
      width: 100%;
      height: 100%;
      transition: transform 0.8s;
      transform-style: preserve-3d;
    }

    /* Класс, который будет включать переворот */
    .product-card-inner.is-flipped {
      transform: rotateY(180deg);
    }

    .product-card-front,
    .product-card-back {
      position: absolute;
      width: 100%;
      height: 100%;
      backface-visibility: hidden;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
    }

    .product-card-front {
      background: #ffffff;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 20px;
      box-sizing: border-box;
    }

    .product-card-front img {
      width: 100%;
      height: 220px;
      object-fit: cover;
      border-radius: 8px;
      margin-bottom: 15px;
    }

    .product-card-front h2 {
      font-size: 20px;
      margin: 0 0 10px;
    }

    .product-card-front .price {
      font-size: 18px;
      color: #e53935;
      margin-bottom: 15px;
    }

    .product-card-front button {
      border: none;
      background: #0072ff;
      color: #fff;
      padding: 10px 20px;
      border-radius: 20px;
      cursor: pointer;
    }

    .product-card-back {
      background: linear-gradient(135deg, #0072ff, #00c6ff);
      color: #fff;
      transform: rotateY(180deg);
      padding: 20px;
      box-sizing: border-box;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 10px;
    }

    .product-card-back h3 {
      margin-top: 0;
    }

    .product-card-back ul {
      padding-left: 18px;
      margin: 0 0 15px;
    }

    .product-card-back button {
      align-self: flex-start;
      border: none;
      background: #fff;
      color: #0072ff;
      padding: 10px 20px;
      border-radius: 20px;
      cursor: pointer;
    }
  </style>
</head>
<body>

  <div class="product-card" id="productCard">
    <div class="product-card-inner">
      <!-- Лицевая сторона -->
      <div class="product-card-front">
        <img src="https://via.placeholder.com/300x220.png?text=Товар" alt="Товар">
        <h2>Наушники SuperSound X1</h2>
        <div class="price">79.99 €</div>
        <button>В корзину</button>
      </div>

      <!-- Обратная сторона -->
      <div class="product-card-back">
        <h3>Характеристики</h3>
        <ul>
          <li>Bluetooth 5.3</li>
          <li>До 24 часов работы</li>
          <li>Шумоподавление</li>
          <li>Быстрая зарядка</li>
        </ul>
        <button>Подробнее</button>
      </div>
    </div>
  </div>

  <script>
    const card = document.getElementById('productCard');
    const inner = card.querySelector('.product-card-inner');

    // Наведение мыши — добавляем класс
    card.addEventListener('mouseenter', () => {
      inner.classList.add('is-flipped');
    });

    // Уводим мышь — убираем класс
    card.addEventListener('mouseleave', () => {
      inner.classList.remove('is-flipped');
    });
  </script>

</body>
</html>
